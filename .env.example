# --- 系統基礎設定 ---
# 儲存模式: postgres / in-memory
STORAGE_TYPE=postgres
# 快取模式: redis / in-memory
CACHE_TYPE=redis

# --- 資料庫連線 (PostgreSQL) ---
DB_USER=researcher
DB_PASSWORD=research_pass
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tw_stock_research

# --- 快取連線 (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Data Provider 設定 ---
# FinMind API Token (非必填，填寫後可提升 Rate Limit)
FINMIND_API_TOKEN=
