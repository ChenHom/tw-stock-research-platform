{
  "name": "tw-stock-research-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "NODE_OPTIONS='--loader ts-node/esm' node --test tests/*.test.ts",
    "validate": "npm run lint && npm test",
    "db:up": "NODE_OPTIONS='--loader ts-node/esm' node src/app/migrate.ts up",
    "db:reset": "NODE_OPTIONS='--loader ts-node/esm' node src/app/migrate.ts reset",
    "db:clear": "NODE_OPTIONS='--loader ts-node/esm' node src/app/migrate.ts clear",
    "research": "NODE_OPTIONS='--loader ts-node/esm' node src/app/commands/run-research.ts",
    "candidates": "NODE_OPTIONS='--loader ts-node/esm' node src/app/commands/run-candidates.ts",
    "dev:tree": "node ./src/app/print-tree.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "postgres": "^3.4.9",
    "redis": "^5.11.0"
  }
}
