{
  "name": "tw-stock-research-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --test --import tsx tests/*.test.ts",
    "validate": "npm run lint && npm test",
    "db:up": "tsx src/app/migrate.ts up",
    "db:clear": "tsx src/app/commands/db-ops.ts clear",
    "db:reset": "tsx src/app/migrate.ts reset",
    "research": "tsx src/app/commands/run-research.ts",
    "candidates": "tsx src/app/commands/run-candidates.ts",
    "run-history": "tsx src/app/commands/run-history.ts",
    "outcomes": "tsx src/app/commands/run-outcomes.ts",
    "performance": "tsx src/app/commands/run-performance.ts",
    "insights": "tsx src/app/commands/run-insights.ts",
    "test:e2e": "tsx tests/e2e-smoke.ts",
    "test:batch": "tsx src/app/commands/run-batch.ts",
    "dev:tree": "node ./src/app/print-tree.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "husky": "^9.1.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "postgres": "^3.4.9",
    "redis": "^5.11.0"
  }
}